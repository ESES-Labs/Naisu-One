# Client-side config (safe to expose)
VITE_API_BASE_URL=https://api-agent.naisu.one

# Server-side proxy config (Vercel project env, DO NOT expose to client)
# Required
# API_BASE_URL=https://api-agent.naisu.one
# MASTER_API_KEY=sk-your-master-api-key-here

# Database for admin auth/session
# Required
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Super admin bootstrap (recommended for first setup)
# At least set SUPERADMIN_USERNAME + one of password vars below
# SUPERADMIN_USERNAME=jar
# SUPERADMIN_PASSWORD_HASH=scrypt$<saltHex>$<hashHex>
# SUPERADMIN_PASSWORD=temporary-plain-password

# Optional session lifetime (default: 8h)
# ADMIN_SESSION_MAX_AGE_SECONDS=28800
